rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===========================
    // HELPER FUNCTIONS
    // ===========================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is admin:
    // 1st: fast path via Firebase custom claims (set by Admin SDK / Cloud Functions)
    // 2nd: fallback — check if a doc exists in the 'admins' collection (no custom claims needed)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'Admin' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    
    // Check if user is resident:
    // 1st: custom claims  2nd: check 'residents' collection
    function isResident() {
      return isAuthenticated() && (
        request.auth.token.role == 'resident' ||
        request.auth.token.role == 'Resident' ||
        exists(/databases/$(database)/documents/residents/$(request.auth.uid))
      );
    }
    
    // Check if user is security staff:
    // 1st: custom claims  2nd: check 'security_staff' collection
    function isSecurity() {
      return isAuthenticated() && (
        request.auth.token.role == 'security' ||
        request.auth.token.role == 'Security' ||
        exists(/databases/$(database)/documents/security_staff/$(request.auth.uid))
      );
    }
    
    // Check if user owns this resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ===========================
    // USERS COLLECTION
    // ===========================
    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isAuthenticated();
      
      // Only admins can create/update users
      allow create, update: if isAdmin();
      
      // Never allow delete
      allow delete: if false;
    }
    
    // ===========================
    // ROLE-SPECIFIC COLLECTIONS
    // ===========================
    match /residents/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    
    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    
    match /security_staff/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    
    // ===========================
    // BILLS COLLECTION
    // ===========================
    match /bills/{billId} {
      // Admins can read all bills
      // Residents can read only their own bills
      allow read: if isAdmin() || 
                     (isResident() && resource.data.residentId == request.auth.uid);
      
      // Only admins can create bills
      allow create: if isAdmin();
      
      // Admins can update any bill
      // Residents can ONLY update their own bills AND only upload payment proof
      // Falls back to Firestore profile check when custom claim token is stale
      allow update: if (
        isAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin'
      ) || (
        isResident() &&
        resource.data.residentId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['proofUrl', 'proofUploadedAt', 'status']) &&
        request.resource.data.status == 'Pending'
      );
      
      // Never allow delete (keep for audit trail)
      allow delete: if false;
    }
    
    // ===========================
    // COMPLAINTS COLLECTION
    // ===========================
    match /complaints/{complaintId} {
      // Admins can read all complaints
      // Residents can read only their own complaints
      allow read: if isAdmin() || 
                     (isResident() && resource.data.residentId == request.auth.uid);
      
      // Residents can create complaints
      // Make sure they can only set their own residentId
      allow create: if isResident() && 
                       request.resource.data.residentId == request.auth.uid;
      
      // Only admins can update (for status changes, resolution)
      allow update: if isAdmin();
      
      // Never allow delete
      allow delete: if false;
    }
    
    // ===========================
    // ANNOUNCEMENTS COLLECTION
    // ===========================
    match /announcements/{announcementId} {
      // Everyone authenticated can read announcements
      allow read: if isAuthenticated();
      
      // Only admins can create/update/delete announcements
      allow create, update, delete: if isAdmin();
    }
    
    // ===========================
    // VEHICLES COLLECTION
    // ===========================
    match /vehicles/{vehicleId} {
      // Everyone authenticated can read
      allow read: if isAuthenticated();
      
      // Residents can register their own vehicles
      allow create: if isResident() && 
                       request.resource.data.residentId == request.auth.uid;
      
      // Residents can update their own vehicles
      // Admins can update any vehicle
      allow update: if isAdmin() || 
                       (isResident() && resource.data.residentId == request.auth.uid);
      
      // Only residents can delete their own vehicles
      allow delete: if isResident() && resource.data.residentId == request.auth.uid;
    }
    
    // ===========================
    // REGISTERED VEHICLES COLLECTION
    // ===========================
    match /registeredVehicles/{vehicleId} {
      // Everyone authenticated can read (security needs this for verification)
      allow read: if isAuthenticated();
      
      // Residents can register their own vehicles
      allow create: if isResident() && 
                       request.resource.data.residentId == request.auth.uid;
      
      // Residents can update their own vehicles
      // Admins can update any vehicle
      allow update: if isAdmin() || 
                       (isResident() && resource.data.residentId == request.auth.uid);
      
      // Only residents can delete their own vehicles
      allow delete: if isResident() && resource.data.residentId == request.auth.uid;
    }
    
    // ===========================
    // VEHICLE LOGS COLLECTION (snake_case - legacy)
    // ===========================
    match /vehicle_logs/{logId} {
      // Everyone authenticated can read
      allow read: if isAuthenticated();
      
      // Security staff can create vehicle logs
      allow create: if isSecurity();
      
      // Security staff can update logs (for exit time)
      allow update: if isSecurity();
      
      // Never allow delete (audit trail)
      allow delete: if false;
    }
    
    // ===========================
    // VEHICLE LOGS COLLECTION (camelCase - current)
    // ===========================
    match /vehicleLogs/{logId} {
      // Everyone authenticated can read
      allow read: if isAuthenticated();
      
      // Security staff OR admin can create vehicle logs
      // Checks both custom claims AND Firestore user profile (fallback for un-refreshed tokens)
      allow create: if isAuthenticated() && (
        isSecurity() || isAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'security' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Security'
      );
      
      // Security staff OR admin can update logs (exit time)
      allow update: if isAuthenticated() && (
        isSecurity() || isAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'security' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Security'
      );
      
      // Never allow delete (audit trail)
      allow delete: if false;
    }
    
    // ===========================
    // MARKETPLACE LISTINGS (legacy collection name)
    // ===========================
    match /marketplace/{listingId} {
      // Everyone authenticated can read approved listings
      allow read: if isAuthenticated();
      
      // Residents can create listings
      allow create: if isResident() && 
                       request.resource.data.postedBy == request.auth.uid;
      
      // Residents can update their own listings
      // Admins can update any listing (for approval/rejection)
      allow update: if isAdmin() || 
                       (isResident() && resource.data.postedBy == request.auth.uid);
      
      // Residents can delete their own listings
      // Admins can delete any listing
      allow delete: if isAdmin() || 
                       (isResident() && resource.data.postedBy == request.auth.uid);
    }
    
    // ===========================
    // LISTINGS COLLECTION (used by MarketplaceListingService)
    // ===========================
    match /listings/{listingId} {
      // Everyone authenticated can read listings
      allow read: if isAuthenticated();
      
      // Residents and Admins can create listings
      allow create: if (isResident() || isAdmin()) && 
                       request.resource.data.postedBy == request.auth.uid;
      
      // Residents can update their own listings
      // Admins can update any listing (for approval/rejection)
      allow update: if isAdmin() || 
                       (isResident() && resource.data.postedBy == request.auth.uid);
      
      // Residents can delete their own listings
      // Admins can delete any listing
      allow delete: if isAdmin() || 
                       (isResident() && resource.data.postedBy == request.auth.uid);
    }
    
    // ===========================
    // COUNTERS COLLECTION (for auto-increment)
    // ===========================
    match /counters/{counterId} {
      // Only read during transactions
      allow read: if isAuthenticated();
      
      // Only allow updates through transactions (from backend logic)
      allow write: if isAuthenticated();
    }
    
    // ===========================
    // NOTIFICATIONS COLLECTION
    // ===========================
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && 
                     resource.data.userId == request.auth.uid;
      
      // Admins can create notifications
      allow create: if isAdmin();
      
      // Users can update their own notifications (mark as read)
      allow update: if isAuthenticated() && 
                       resource.data.userId == request.auth.uid;
      
      // Never allow delete
      allow delete: if false;
    }
  }
}
