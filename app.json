{
  "expo": {
    "name": "eRoyal",
    "slug": "eRoyal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "eroyal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "eRoyal uses the camera to scan vehicle license plates at the security gate."
      }
    },
    "android": {
      "package": "com.eroyal.app",
      "icon": "./assets/images/icon.png",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "eRoyal",
      "shortName": "eRoyal",
      "description": "Royal City Housing Society Management App",
      "themeColor": "#0D9488",
      "backgroundColor": "#0D9488",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "eRoyal uses the camera to scan vehicle license plates at the security gate."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0D9488",
          "dark": {
            "backgroundColor": "#0D9488"
          }
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ee3207c7-66b8-45f2-9c2a-ad87997e1f69"
      }
    }
  }
}
